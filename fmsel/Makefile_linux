objdir = ./objs

PREFIX ?= /usr
BINDIR = $(PREFIX)/bin
LIBDIR = $(PREFIX)/lib
LICDIR = $(PREFIX)/share/licenses/libfmsel
INCDIR = $(PREFIX)/include

CC ?= gcc
CXX ?= g++

CFLAGS_ALL = -O2 -fPIC -fvisibility=hidden $(CFLAGS)
CXXFLAGS_ALL = -O2 -fPIC -fvisibility=hidden $(CXXFLAGS)
CPPFLAGS_C_ALL = -std=gnu99 -Wall -Wextra -Wno-unused -Wno-unused-result $(CPPFLAGS)
CPPFLAGS_CXX_ALL = -std=gnu++11 $(L7ZIP_INC) -Wall -Wextra -Wno-cast-function-type -Wno-format-security -Wno-unused -Wno-unused-result -D_DEFAULT_SOURCE -D_BSD_SOURCE -D_LARGEFILE_SOURCE -DLARGEFILE64_SOURCE -D_FILE_OFFSET_BITS=64 -D__int64="long long int" $(CPPFLAGS)

ifeq ($(STATIC),)
	LDFLAGS_FLTK = $(shell fltk-config --use-images --ldflags)
else
	LDFLAGS_FLTK = $(shell fltk-config --use-images --ldstaticflags)
endif

LDFLAGS_ALL = $(L7ZIP_LIB) $(LDFLAGS_FLTK) -Wl,--strip-all -Wl,--no-undefined -Wl,-soname,$(SONAME) $(LDFLAGS)

ifneq ($(USE_PATH_MAX),)
	CPPFLAGS_CXX_ALL += -DUSE_PATH_MAX
endif
ifneq ($(USE_XDG),)
	CPPFLAGS_CXX_ALL += -DUSE_XDG
endif
ifneq ($(AUDIO_SUPPORT),)
	CPPFLAGS_CXX_ALL += -DAUDIO_SUPPORT
endif
ifneq ($(MP3_SUPPORT),)
	CPPFLAGS_CXX_ALL += -DMP3_SUPPORT
endif
ifneq ($(OGG_SUPPORT),)
	CPPFLAGS_CXX_ALL += -DOGG_SUPPORT
endif
ifneq ($(OPUS_SUPPORT),)
	CPPFLAGS_CXX_ALL += -DOPUS_SUPPORT
endif
ifneq ($(FLAC_SUPPORT),)
	CPPFLAGS_CXX_ALL += -DFLAC_SUPPORT
endif
ifneq ($(T3_SUPPORT),)
	CPPFLAGS_CXX_ALL += -DT3_SUPPORT
endif
ifneq ($(GLML_SUPPORT),)
	CPPFLAGS_CXX_ALL += -DGLML_SUPPORT
endif

LIBS = -l7zip $(shell pkg-config --libs minizip)

ifneq ($(OGG_SUPPORT),)
	LIBS += $(shell pkg-config --libs vorbisfile vorbis)
endif
ifneq ($(OPUS_SUPPORT),)
	LIBS += $(shell pkg-config --libs opusfile opus)
endif
ifneq ($(FLAC_SUPPORT),)
	LIBS += $(shell pkg-config --libs flac)
endif
ifneq ($(OGG_SUPPORT)$(OPUS_SUPPORT)$(FLAC_SUPPORT),)
	LIBS += $(shell pkg-config --libs ogg)
endif

SONAME ?= libfmsel.so.1

TOOL_LIBS = -l:$(SONAME)

FMSEL_OBJS = $(objdir)/archive.o \
			$(objdir)/Fl_Html_View.o \
			$(objdir)/fmsel.o \
			$(objdir)/lang.o \
			$(objdir)/os.o
FLTK_OBJS = $(objdir)/Fl_Table.o \
			$(objdir)/Fl_Table_Row.o \
			$(objdir)/Fle_Colors.o \
			$(objdir)/Fle_Schemes.o
TOOL_OBJS = $(objdir)/fmsel_launch.o

ifneq ($(AUDIO_SUPPORT),)
	FMSEL_OBJS += $(objdir)/mp3.o
endif
ifneq ($(T3_SUPPORT),)
	FMSEL_OBJS += $(objdir)/glml.o
else ifneq ($(GLML_SUPPORT),)
	FMSEL_OBJS += $(objdir)/glml.o
endif

.PHONY: all install clean install_link install_tools

ifeq ($(BUILD_TOOLS),)
all: $(objdir) $(SONAME)
else
all: $(objdir) $(SONAME) fmsel
endif

install: install_link install_tools
	mkdir -p $(DESTDIR)$(LIBDIR)
	mkdir -p $(DESTDIR)$(LICDIR)
	mkdir -p $(DESTDIR)$(INCDIR)
	install -p -m 755 $(SONAME) $(DESTDIR)$(LIBDIR)
	install -p -m 644 COPYING $(DESTDIR)$(LICDIR)
	install -p -m 644 fmsel.h $(DESTDIR)$(INCDIR)

clean:
	rm -rf $(objdir)
	rm -f $(SONAME)
	rm -f fmsel

install_link:
ifneq ($(SONAME),libfmsel.so)
	mkdir -p $(DESTDIR)$(LIBDIR)
	ln -s $(SONAME) $(DESTDIR)$(LIBDIR)/libfmsel.so
endif

install_tools:
ifneq ($(BUILD_TOOLS),)
	mkdir -p $(DESTDIR)$(BINDIR)
	install -p -m 755 fmsel $(DESTDIR)$(BINDIR)
endif

$(objdir):
	mkdir -p $@

$(objdir)/%.o: ./Fl_Table/%.cxx
	$(CXX) $(CXXFLAGS_ALL) $(CPPFLAGS_CXX_ALL) -c -o $@ $<

$(objdir)/%.o: ../zlibcomp/%.c
	$(CC) $(CFLAGS_ALL) $(CPPFLAGS_C_ALL) -c -o $@ $<

$(objdir)/%.o: %.cpp
	$(CXX) $(CXXFLAGS_ALL) $(CPPFLAGS_CXX_ALL) -I./Fl_Table -c -o $@ $<

$(objdir)/%.o: %.c
	$(CC) $(CFLAGS_ALL) $(CPPFLAGS_C_ALL) -c -o $@ $<

$(objdir)/archive.o: archive.h os.h lang.h dbgutil.h
$(objdir)/Fl_Html_View.o: Fl_Html_View.H flstring.h
$(objdir)/fmsel.o: fmsel.h os.h archive.h lang.h dbgutil.h glml.h Fl_Html_View.H ./Fl_Table/Fl_Table_Row.H ./Fl_Table/Fl_Table.H mp3.h icons.h fl_mainwnd.h fl_taged.h fl_mainwnd.cpp.h fl_taged.cpp.h Fle_Colors.hpp Fle_Schemes.hpp
$(objdir)/lang.o: lang.h os.h dbgutil.h
$(objdir)/mp3.o: mp3.h os.h lang.h dbgutil.h
$(objdir)/os.o: lang.h os.h dbgutil.h
$(objdir)/glml.o: glml.h os.h

$(objdir)/Fl_Table.o: ./Fl_Table/Fl_Table.H
$(objdir)/Fl_Table_Row.o: ./Fl_Table/Fl_Table_Row.H ./Fl_Table/Fl_Table.H

$(objdir)/fmsel_launch.o: fmsel.h

$(objdir)/adler32.o: ../zlibcomp/zutil.h ../zlibcomp/zlib.h ../zlibcomp/zconf.h
$(objdir)/compress.o: ../zlibcomp/zlib.h ../zlibcomp/zconf.h
$(objdir)/crc32.o: ../zlibcomp/zutil.h ../zlibcomp/zlib.h ../zlibcomp/zconf.h ../zlibcomp/crc32.h
$(objdir)/deflate.o: ../zlibcomp/deflate.h ../zlibcomp/zutil.h ../zlibcomp/zlib.h ../zlibcomp/zconf.h
$(objdir)/ioapi.o: ../zlibcomp/zlib.h ../zlibcomp/zconf.h ../zlibcomp/ioapi.h
$(objdir)/iowin32.o: ../zlibcomp/zlib.h ../zlibcomp/zconf.h ../zlibcomp/ioapi.h ../zlibcomp/iowin32.h
$(objdir)/trees.o: ../zlibcomp/deflate.h ../zlibcomp/zutil.h ../zlibcomp/zlib.h ../zlibcomp/zconf.h ../zlibcomp/trees.h
$(objdir)/zip.o: ../zlibcomp/zlib.h ../zlibcomp/zconf.h ../zlibcomp/zip.h ../zlibcomp/ioapi.h ../zlibcomp/crypt.h
$(objdir)/zutil.o: ../zlibcomp/zutil.h ../zlibcomp/zlib.h ../zlibcomp/zconf.h

$(SONAME): $(FMSEL_OBJS) $(FLTK_OBJS)
	$(CXX) $(CXXFLAGS_ALL) -shared $^ -o $@ $(LDFLAGS_ALL) $(LIBS)

fmsel: $(TOOL_OBJS) $(SONAME)
	$(CC) $(CFLAGS_ALL) $(LDFLAGS) -L. $(TOOL_OBJS) -o $@ $(TOOL_LIBS)
